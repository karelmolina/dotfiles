# LazySQL MariaDB via SSH tunnel
# Copy this file to .env and fill in your values:
#   cp lazysql/.env.example lazysql/.env

LAZYSQL_MARIADB_DB_NAME=your_database_name
LAZYSQL_MARIADB_DB_USER=your_db_user
LAZYSQL_MARIADB_DB_PASSWORD=your_db_password
LAZYSQL_MARIADB_SSH_KEY=/path/to/your/key.pem
LAZYSQL_MARIADB_SSH_USER=your_ssh_user
LAZYSQL_MARIADB_SSH_HOST=your.server.com
