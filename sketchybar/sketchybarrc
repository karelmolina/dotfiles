#!/bin/bash

# Plugin directory
PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar Appearance #####
# https://felixkratz.github.io/SketchyBar/config/bar

sketchybar --bar \
  position=top \
  display=main \
  height=36 \
  margin=10 \
  y_offset=4 \
  corner_radius=12 \
  color=0x30000000 \
  blur_radius=30 \
  shadow=on \
  border_width=1 \
  border_color=0x22ffffff \
  padding_left=16 \
  padding_right=16 \
  sticky=on \
  topmost=off

##### Defaults #####
# https://felixkratz.github.io/SketchyBar/config/items

defaults=(
  padding_left=4
  padding_right=4
  icon.font="JetBrainsMono Nerd Font:Bold:14.0"
  label.font="JetBrainsMono Nerd Font:Bold:12.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=6
  icon.padding_right=2
  label.padding_left=2
  label.padding_right=6
  background.height=26
  background.corner_radius=8
)

sketchybar --default "${defaults[@]}"

##### LEFT: Front App #####
sketchybar --add item front_app left \
  --set front_app \
    icon.drawing=off \
    label.font="JetBrainsMono Nerd Font:Bold:13.0" \
    label.padding_left=8 \
    label.padding_right=8 \
    script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

##### LEFT: Aerospace Workspaces #####
sketchybar --add event aerospace_workspace_change

# Hardcode all configured aerospace workspaces so empty/unvisited ones still appear.
# This must match the workspace ids defined in aerospace/.config/aerospace/aerospace.toml
for sid in 1 2 3 4 5 e m c b s z; do
  sketchybar --add item space.$sid left \
    --set space.$sid \
      label="$sid" \
      label.font="JetBrainsMono Nerd Font:Bold:11.0" \
      label.padding_left=6 \
      label.padding_right=6 \
      background.height=22 \
      background.corner_radius=5 \
      background.drawing=off \
      click_script="aerospace workspace $sid"
done

# Hidden refresher that polls aerospace and updates all workspaces
sketchybar --add item aerospace_refresh left \
  --set aerospace_refresh \
    drawing=off \
    updates=on \
    update_freq=1 \
    script="$PLUGIN_DIR/aerospace_refresh.sh" \
  --subscribe aerospace_refresh aerospace_workspace_change

##### LEFT: Aerospace Mode Indicator #####
sketchybar --add item aerospace_mode left \
  --set aerospace_mode \
    drawing=off \
    icon= \
    icon.padding_left=8 \
    icon.padding_right=2 \
    label.padding_left=2 \
    label.padding_right=6 \
    background.height=22 \
    background.corner_radius=5 \
    background.color=0x33ffffff \
    update_freq=1 \
    script="$PLUGIN_DIR/aerospace_mode.sh"

##### RIGHT: Separator helper #####
# We add items in reverse order (right to left) for cleaner layout

##### RIGHT: Clock #####
sketchybar --add item clock right \
  --set clock \
    update_freq=10 \
    label.padding_right=6 \
    icon= \
    icon.padding_left=8 \
    script="$PLUGIN_DIR/clock.sh"

##### RIGHT: Volume #####
sketchybar --add item volume right \
  --set volume \
    icon= \
    icon.padding_left=8 \
    script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

##### RIGHT: Battery #####
sketchybar --add item battery right \
  --set battery \
    update_freq=60 \
    icon.padding_left=8 \
    script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

##### Force all scripts to run the first time #####
sketchybar --update
