#!/bin/bash
# OS Detection and dispatch script

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

detect_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        if [ "$ID" = "omarchy" ]; then
            echo "omarchy"
        else
            echo "unsupported"
        fi
    elif [ "$(uname -s)" = "Darwin" ]; then
        echo "macos"
    else
        echo "unsupported"
    fi
}

main() {
    local os
    os=$(detect_os)

    echo "=============================================="
    echo "Dotfiles Installer"
    echo "=============================================="
    echo "Detected OS: $os"
    echo ""

    case "$os" in
        omarchy)
            echo "Running Omarchy installer..."
            bash "$SCRIPT_DIR/scripts/omarchy.sh" "$@"
            ;;
        macos)
            echo "Running macOS installer..."
            bash "$SCRIPT_DIR/scripts/macos.sh" "$@"
            ;;
        *)
            echo "ERROR: Unsupported operating system: $os"
            echo ""
            echo "Supported systems:"
            echo "  - macOS"
            echo "  - Omarchy Linux"
            exit 1
            ;;
    esac
}

main "$@"
