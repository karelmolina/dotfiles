#!/bin/bash
# OS Detection and dispatch script

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

detect_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "$ID"
    elif [ "$(uname -s)" = "Darwin" ]; then
        echo "macos"
    else
        echo "unknown"
    fi
}

detect_version() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        echo "$VERSION_ID"
    fi
}

main() {
    local os=$(detect_os)
    local version=$(detect_version)
    
    echo "=============================================="
    echo "Dotfiles Installer"
    echo "=============================================="
    echo "Detected OS: $os"
    echo "Version: $version"
    echo ""
    
    case "$os" in
        fedora)
            echo "Running Fedora installer..."
            bash "$SCRIPT_DIR/scripts/fedora.sh" "$@"
            ;;
        ubuntu)
            echo "Ubuntu support coming soon!"
            exit 1
            ;;
        debian)
            echo "Debian support coming soon!"
            exit 1
            ;;
        arch)
            echo "Arch support coming soon!"
            exit 1
            ;;
        macos)
            echo "macOS support coming soon!"
            exit 1
            ;;
        *)
            echo "ERROR: Unsupported operating system: $os"
            echo ""
            echo "Supported systems:"
            echo "  - Fedora (43+)"
            echo "  - Ubuntu (coming soon)"
            echo "  - Debian (coming soon)"
            echo "  - Arch (coming soon)"
            echo "  - macOS (coming soon)"
            exit 1
            ;;
    esac
}

main "$@"
